# Frontend environment (optional — see DEPLOYMENT.md)
#
# Used ONLY at build time: npm run build
# Copy to .env.production if API is on a different host than the UI.
#
# DEFAULT (recommended): leave empty — UI and API share the same domain/port.
# VITE_API_URL=

# SPLIT DEPLOYMENT ONLY — UI and API on different domains:
# VITE_API_URL=https://api.yourcompany.com
