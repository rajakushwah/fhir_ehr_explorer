NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your-password-here
NEO4J_DATABASE=fhirexplorer

MAX_SEARCH_RESULTS=25
MAX_PATIENT_RESULTS=50

# Logging — DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_HTTP_LEVEL=INFO
LOG_QUERY_LEVEL=INFO
LOG_SEARCH_LEVEL=INFO
LOG_COHORT_LEVEL=INFO
LOG_GRAPH_LEVEL=INFO
LOG_INGESTION_LEVEL=INFO
LOG_NEO4J_DRIVER_LEVEL=WARNING
# Set true to include Cypher snippets in query debug logs
LOG_QUERY_DETAIL=false

# Ingestion performance — see docs/INGESTION_PERFORMANCE.md
INGEST_USE_PROCESSES=true
INGEST_MAP_WORKERS=4
INGEST_WRITE_WORKERS=4
INGEST_TX_BATCH_SIZE=3
INGEST_CYPHER_BATCH_SIZE=1000
INGEST_SKIP_OBSERVATION_CATEGORIES=social-history,survey,therapy,activity
INGEST_MAX_OBSERVATIONS_PER_PATIENT=400
# NEO4J_IMPORT_DIR=C:\Users\ADMIN\.Neo4jDesktop2\Data\dbmss\dbms-<id>\import
